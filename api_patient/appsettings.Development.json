{
  "Jwt": {
    "Issuer": "api_security",
    "Audience": "*",
    "Secret": "DiplomadoMicroservicios2025SecretoJTWApiSecurity",
    "ExpiryMinutes": 480
  },
  "RabbitMQ": {
    "HostName": "localhost",
    "Port": 5672,
    "UserName": "admin",
    "Password": "admin",
    "VirtualHost": "/",
    "ReconnectDelaySeconds": 5,
    "MaxReconnectAttempts": 0,
    "FoodPlansExchange": "meal-plans",
    "FoodPlansQueue": "ms-patients-queue",
    "FoodPlanCreatedRoutingKey": "meal-plan.created",
    "FoodPlanUpdatedRoutingKey": "meal-plan.updated",
    "PatientsExchange": "patients",
    "PatientCreatedRoutingKey": "patient.created",
    "PatientUpdatedRoutingKey": "patient.updated"
  },
  "Telemetry": {
    "OtlpEndpoint": "http://localhost:4317"
  },
  "Loki": {
    "Uri": "http://localhost:3100"
  },
  "Consul": {
    "Host": "http://localhost:8500",
    "ServiceName": "api-patient",
    "ServiceAddress": "localhost",
    "ServicePort": 5002
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Serilog": {
    "Using": [
      "Serilog.Sinks.Console",
      "Serilog.Formatting.Compact",
      "Serilog.Enrichers.Span",
      "Serilog.Sinks.Grafana.Loki"
    ],
    "MinimumLevel": {
      "Default": "Debug",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    },
    "Enrich": [ "FromLogContext", "WithSpan" ],
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "formatter": "Serilog.Formatting.Compact.CompactJsonFormatter, Serilog.Formatting.Compact"
        }
      }
    ]
  }
}
