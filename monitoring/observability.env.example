# Copiar a observability.env (no commitear secretos reales).
# Uso: docker compose -f docker-compose.observability.yml --env-file monitoring/observability.env up -d

# Grafana (http://localhost:3000 por defecto)
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=CambiarGrafanaEnProduccion

# Puertos opcionales (mapear en el host)
# GRAFANA_PORT=3000
# PROMETHEUS_PORT=9090
# SEQ_PORT=5341
# JAEGER_UI_PORT=16686
# OTLP_GRPC_PORT=4317
# OTLP_HTTP_PORT=4318
# NODE_EXPORTER_PORT=9100

# Seq: la primera vez abre http://localhost:5341 y define usuario/contraseña de administrador.
# Ingesta desde la API/worker: SEQ_SERVER_URL=http://seq:80 en docker-compose-dev (por defecto).
