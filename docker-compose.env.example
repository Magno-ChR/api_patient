# Copiar a .env en la raíz del repo (junto a docker-compose-dev.yml).
# Requiere la red Docker externa develop_nutricenter_net (la del servidor / compose proyecto "develop").
# Si en local aún no existe: docker network create develop_nutricenter_net
# Así la API y el worker envían trazas a Jaeger y logs a Seq en esa misma red.

OTEL_EXPORTER_OTLP_ENDPOINT=http://jaeger:4317
OTEL_EXPORTER_OTLP_PROTOCOL=grpc
SEQ_SERVER_URL=http://seq:80
SEQ_FIRSTRUN_ADMINPASSWORD=ChangeMeSeqAdmin123!
