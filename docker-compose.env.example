# Copiar a .env en la raíz del repo (junto a docker-compose-dev.yml).
# Requiere la red Docker externa develop_nutricenter_net.
# Si en local aún no existe: docker network create develop_nutricenter_net
#
# RabbitMQ externo:
# - Cambia el host/puerto/credenciales por los de tu broker AMQP.
# - Si la topología externa no coincide con los nombres por defecto, ajusta también exchanges, cola y routing keys.
#
# Observabilidad (mismo criterio que ms-logistic vía INFRA_HOST):
# - OTLP: Telemetry__OtlpEndpoint = http://INFRA_HOST:4317 (compose).
# - Logs: Serilog GrafanaLoki = http://INFRA_HOST:3100 (compose). Grafana en :3000 es UI, no reemplaza Loki.
# - Opcional: OTEL_EXPORTER_OTLP_ENDPOINT, LOKI_URL y SEQ_SERVER_URL para forzar otros endpoints.

INFRA_HOST=165.22.148.216

RABBITMQ__PORT=5672
RABBITMQ__USERNAME=admin
RABBITMQ__PASSWORD=admin
RABBITMQ__VIRTUALHOST=/
RABBITMQ__FOODPLANS_EXCHANGE=meal-plans
RABBITMQ__FOODPLANS_QUEUE=ms-patients-queue
RABBITMQ__FOODPLAN_CREATED_ROUTING_KEY=meal-plan.created
RABBITMQ__FOODPLAN_UPDATED_ROUTING_KEY=meal-plan.updated
RABBITMQ__PATIENTS_EXCHANGE=patients
RABBITMQ__PATIENT_CREATED_ROUTING_KEY=patient.created
RABBITMQ__PATIENT_UPDATED_ROUTING_KEY=patient.updated
RABBITMQ__RECONNECT_DELAY_SECONDS=5
RABBITMQ__MAX_RECONNECT_ATTEMPTS=0

OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_EXPORTER_OTLP_PROTOCOL=grpc
LOKI_URL=
SEQ_SERVER_URL=
